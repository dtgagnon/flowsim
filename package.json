{
  "name": "flowsim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fluid simulation for medical device test loops — interactive schematic builder with hydraulic network solver.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "node --import tsx --test src/physics/*.test.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
